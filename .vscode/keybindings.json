[
  {
    "key": "alt+e s",
    "command": "ethos.start",
    "when": "editorTextFocus"
  },
  {
    "key": "alt+e d",
    "command": "ethos.openDisplay",
    "when": "editorTextFocus"
  },
  {
    "key": "alt+e t",
    "command": "ethos.openTelemetry",
    "when": "editorTextFocus"
  },
  {
    "key": "alt+e x",
    "command": "ethos.stop",
    "when": "editorTextFocus"
  },
  {
    "key": "alt+e r",
    "command": "runCommands",
    "args": {
      "commands": [
        "ethos.stop",
        "ethos.start"
      ]
    },
    "when": "editorTextFocus"
  }
]
